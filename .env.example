# PostgreSQL
POSTGRES_DB=kutup
POSTGRES_USER=kutup
POSTGRES_PASSWORD=change_me_strong_password

# JWT - generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# SeaweedFS S3
S3_ACCESS_KEY=kutup
S3_SECRET_KEY=change_me_s3_secret
S3_BUCKET=kutup-files
S3_REGION=us-east-1

# Total storage capacity advertised to the admin UI, in bytes.
# Used + free + percentage are derived from this. Leave unset / 0 to hide
# the capacity readout (UI just shows used bytes). Examples:
#   100 GB = 107374182400
#   500 GB = 536870912000
#     1 TB = 1099511627776
# STORAGE_TOTAL_BYTES=536870912000

# App
APP_ENV=production

# Public base URL of this server — used for federation invite links
# Set to your actual domain, e.g. https://kutup.example.com
SERVER_URL=http://kutup.local

# Admin bootstrap — comma-separated email:username:password triples
# Accounts are created on first server start; admins must complete setup on first login
ADMIN_ACCOUNTS=admin@example.com:admin:change_me_admin_password
