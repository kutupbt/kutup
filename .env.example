# PostgreSQL
POSTGRES_DB=kutup
POSTGRES_USER=kutup
POSTGRES_PASSWORD=change_me_strong_password

# JWT - generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# SeaweedFS S3
S3_ACCESS_KEY=kutup
S3_SECRET_KEY=change_me_s3_secret
S3_BUCKET=kutup-files
S3_REGION=us-east-1

# SeaweedFS master endpoint — the admin dashboard probes it for real
# storage capacity + usage. Default works for the bundled docker-compose.
# Leave blank to disable the probe (the admin UI then falls back to
# STORAGE_TOTAL_BYTES below).
SEAWEEDFS_MASTER_URL=http://seaweedfs-master:9333

# Fallback total storage capacity for the admin UI, in bytes — used only
# when the SeaweedFS probe above is unavailable. Leave unset / 0 to hide
# the capacity readout. Examples:
#   100 GB = 107374182400
#   500 GB = 536870912000
#     1 TB = 1099511627776
# STORAGE_TOTAL_BYTES=536870912000

# Days a trashed file/folder stays restorable before the hourly sweeper
# purges it permanently. 0 disables the automatic purge. Default: 30.
# TRASH_RETENTION_DAYS=30

# Chat ciphertext/idempotency retention and inactive-device expiry. Each is
# enforced hourly; 0 disables that policy.
# CHAT_MAILBOX_RETENTION_DAYS=30
# CHAT_SEND_RETENTION_DAYS=30
# CHAT_DEVICE_EXPIRY_DAYS=90

# Rate limits (per client IP; defaults shown). The backend resolves the client
# IP from the proxy-set X-Real-IP header — keep the backend unreachable except
# through nginx or these limits key on the proxy's address.
# RATE_LIMIT_LOGIN_PER_MIN=10
# RATE_LIMIT_PREFLIGHT_PER_MIN=20
# RATE_LIMIT_REGISTER_PER_HOUR=10
# RATE_LIMIT_RECOVERY_PER_HOUR=5
# RATE_LIMIT_FED_USERS_PER_MIN=60
# RATE_LIMIT_ADMIN_PER_MIN=120
# RATE_LIMIT_CHAT_KEYS_PER_MIN=30       # per authenticated account
# RATE_LIMIT_CHAT_KEYS_IP_PER_MIN=120   # coarse outer IP wall

# Per-account login lockout: N failed password attempts lock the email out
# for the cooldown (defaults shown).
# LOGIN_LOCKOUT_THRESHOLD=5
# LOGIN_LOCKOUT_MINUTES=15

# App
APP_ENV=production

# Public base URL of this server — used for federation invite links
# Set to your actual domain, e.g. https://kutup.example.com
SERVER_URL=http://kutup.local

# Break-glass admin bootstrap — a single email:username:password triple.
# Created on first server start; the admin completes setup on first login.
# This account is the protected break-glass admin: it can never be demoted,
# disabled, or deleted via the API/UI, so the server maintainer always has
# a working admin. Promote additional admins from inside the app.
ADMIN_ACCOUNT=admin@example.com:admin:change_me_admin_password
