# Build context for Dockerfile.server is the repo root, but the image only needs the Cargo
# workspace (Cargo.toml, Cargo.lock, crates/). Everything else is excluded to keep the
# context small/fast — most importantly the multi-GB target/ dir.
target/
.git/
**/node_modules/
# The frontend image now uses the repo root so it can compile kutup-chat-core
# to WASM. Keep its sources in context while excluding generated/heavy assets.
frontend/dist/
frontend/public/chat-wasm/
frontend/public/onlyoffice/dist/
frontend/public/onlyoffice/templates/
src-tauri/
backend/
cmd/
nginx/
docs/
**/*.md
.env
.env.*
**/target/
