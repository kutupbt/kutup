{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Cross-platform permissions for Kutup's main webview. Desktop-only filesystem scopes ($HOME / $DOWNLOAD) live in desktop.json so they don't break the mobile build. Tighten / split per route once the app surface is mature.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:default",
    "core:path:default",
    "core:app:default",
    "core:webview:default",

    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",

    "fs:default",

    "http:default",
    "shell:allow-open",
    "os:default",
    "notification:default",
    "store:default",
    "process:default"
  ]
}
